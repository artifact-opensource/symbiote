{
  "name": "mach6-core",
  "version": "2.2.0",
  "description": "Mach6 — Multi-channel AI agent framework. Persistent daemon, real-time interrupts, tool execution. Runs on a laptop.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mach6": "dist/index.js"
  },
  "files": [
    "dist",
    "web",
    "README.md",
    "LICENSE",
    "mach6.example.json",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/gateway/daemon.js --config=mach6.json",
    "dev": "tsc && node dist/index.js",
    "init": "tsc && node dist/cli/wizard.js"
  },
  "keywords": [
    "ai-agent",
    "ai-agent-framework",
    "llm-agent",
    "autonomous-agent",
    "agentic-ai",
    "tool-calling",
    "multi-channel",
    "discord-bot",
    "whatsapp-bot",
    "chatbot",
    "llm",
    "groq",
    "openai",
    "anthropic",
    "claude",
    "grok",
    "ollama",
    "github-copilot",
    "mcp",
    "model-context-protocol",
    "typescript",
    "nodejs",
    "local-first",
    "self-hosted",
    "open-source"
  ],
  "author": "Artifact Virtual <hello@artifactvirtual.com> (https://artifactvirtual.com)",
  "license": "MIT",
  "homepage": "https://github.com/Artifact-Virtual/mach6#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Artifact-Virtual/mach6.git"
  },
  "bugs": {
    "url": "https://github.com/Artifact-Virtual/mach6/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "undici": ">=6.23.0"
  }
}
